{
  "command_timeout": 5,
  "templates_folder": "Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "Projects",
      "template": "Templates/Project Template.md"
    },
    {
      "folder": "Daily",
      "template": "Templates/Daily Note.md"
    },
    {
      "folder": "Reviews",
      "template": "Templates/Weekly Review.md"
    },
    {
      "folder": "_Personal/Meetings",
      "template": "Templates/Personal Meeting Note.md"
    },
    {
      "folder": "_Personal/Projects",
      "template": "Templates/Personal Project.md"
    },
    {
      "folder": "_Personal/Reviews",
      "template": "Templates/Personal Weekly Review.md"
    },
    {
      "folder": "People",
      "template": "Templates/Person.md"
    },
    {
      "folder": "Reads",
      "template": "Templates/Read.md"
    },
    {
      "folder": "CPD",
      "template": "Templates/CPD Entry.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
